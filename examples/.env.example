# Uncomment and populate the values you prefer, then copy to `.env`

# GH_TOKEN=ghp_your_github_pat
# GITHUB_TOKEN=${GH_TOKEN}

# OPENAI_API_KEY=sk-your-openai-key

# GIT_AUTHOR_NAME=Your Name
# GIT_AUTHOR_EMAIL=you@example.com
# GIT_COMMITTER_NAME=${GIT_AUTHOR_NAME}
# GIT_COMMITTER_EMAIL=${GIT_AUTHOR_EMAIL}

# LOCAL_UID=1000
# LOCAL_GID=1000

# Cache directories for runtime-installed tools
# Point to persistent locations outside the project to preserve packages across rebuilds
# Default: ./data/<cache-name> (relative to docker-compose.yml location)
# Alternative: Use ~/ path for cross-project persistence

# NPM package cache (speeds up agent downloads)
# NPM_CACHE_DIR=${HOME}/.docker-npm-cache
# NPM_MODULES_DIR=${HOME}/.docker-npm-modules

# Playwright browser cache
# PLAYWRIGHT_CACHE_DIR=${HOME}/.docker-playwright-cache

# pipx Python tools cache
# PIPX_CACHE_DIR=${HOME}/.docker-pipx-cache

# Cursor CLI cache
# CURSOR_CACHE_DIR=${HOME}/.docker-cursor-cache
