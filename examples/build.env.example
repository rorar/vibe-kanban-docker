# Coding Agents - set to "true" to install
# Available agents (case-insensitive, use AGENT_<NAME>=true):
#
# Agent       | Description
# ------------|---------------------------------
# codex       | OpenAI Codex (installed by default)
# claude      | Anthropic Claude Code
# gemini      | Google Gemini CLI
# copilot     | GitHub Copilot CLI
# amp         | Amp Code
# cursor      | Cursor Agent CLI
# opencode    | SST OpenCode
# droid       | Factory Droid
# clauderouter| Claude Code Router
# qwen        | Qwen Code

# AGENT_codex=true  # Already installed by default
# AGENT_claude=true
# AGENT_gemini=true
# AGENT_copilot=true
# AGENT_amp=true
# AGENT_cursor=true
# AGENT_opencode=true
# AGENT_droid=true
# AGENT_clauderouter=true
# AGENT_qwen=true

# Playwright E2E Testing
# Set PLAYWRIGHT_BROWSERS to install browsers (space-separated)
# Available: chromium firefox webkit
# PLAYWRIGHT_BROWSERS=chromium firefox webkit
