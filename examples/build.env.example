# Runtime Tool Installation
# These environment variables are used at container startup to install tools.
# Set via docker run -e, docker-compose environment, or UnRAID template.
# Supports both space-separated and comma-separated values.

# Coding Agents (space or comma-separated agent names)
# Available: claude, gemini, copilot, amp, cursor, opencode, droid, clauderouter, qwen
# RUNTIME_AGENTS=claude gemini
# RUNTIME_AGENTS=claude,gemini

# Playwright E2E Testing (space or comma-separated browser names)
# Available: chromium, firefox, webkit
# RUNTIME_PLAYWRIGHT_BROWSERS=chromium firefox
# RUNTIME_PLAYWRIGHT_BROWSERS=chromium,firefox,webkit

# Testing Tools (space or comma-separated tool names)
# Available: vitest, jest, msw
# RUNTIME_TESTING_TOOLS=vitest jest msw
# RUNTIME_TESTING_TOOLS=vitest,jest,msw
